// Wato - Social Challenge App Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  MODERATOR
  ADMIN
}

enum ChallengeStatus {
  PENDING_REVIEW
  ACTIVE
  REJECTED
  HIDDEN
}

enum ChallengeCategory {
  FITNESS
  SKILL
  CREATIVITY
  ADVENTURE
  FUNNY
}

enum AttemptStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
}

enum VerificationVoteType {
  VERIFY
  REJECT
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum ReportTargetType {
  CHALLENGE
  ATTEMPT
}

enum ReportStatus {
  OPEN
  RESOLVED
  DISMISSED
}

enum AttemptReactionType {
  FIRE
  CLAP
  LAUGH
  WOW
  STRONG
}

enum NotificationType {
  FRIEND_REQUEST
  FRIEND_ACCEPTED
  FRIEND_ACTIVITY
  FOLLOW
  VERIFICATION_REQUEST
  CHALLENGE_REVIEW_REQUEST
  VERIFICATION_VOTE
  ATTEMPT_APPROVED
  ATTEMPT_REJECTED
  ATTEMPT_COMMENT
  ATTEMPT_REACTION
  ATTEMPT_UPVOTE
  STREAK_MILESTONE
  TEAM_INVITE
  MESSAGE
  ACHIEVEMENT
}

enum TeamRole {
  OWNER
  ADMIN
  MEMBER
}

model User {
  id                String         @id @default(cuid())
  email             String         @unique
  username          String         @unique
  name              String?
  password          String
  avatarUrl         String?
  bio               String?        @db.VarChar(280)
  isPrivate         Boolean        @default(false)
  totalPoints       Int            @default(0)
  role              UserRole       @default(USER)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  
  // Relations
  challenges        Challenge[]
  attempts          Attempt[]
  verificationVotes VerificationVote[]
  attemptComments   AttemptComment[]
  attemptCommentUpvotes AttemptCommentUpvote[]
  attemptUpvotes    AttemptUpvote[]
  attemptReactions  AttemptReaction[]
  pointsLedger      PointsLedger[]
  notifications     Notification[]
  reports           Report[]
  
  // Friendship relations
  friendRequestsSent     Friendship[] @relation("FriendRequester")
  friendRequestsReceived Friendship[] @relation("FriendAddressee")
  
  // Message relations
  messageThreadsA   MessageThread[] @relation("ThreadUserA")
  messageThreadsB   MessageThread[] @relation("ThreadUserB")
  messagesSent      Message[]

  // Social graph
  followers         Follow[]       @relation("Following")
  following         Follow[]       @relation("Follower")
  streak            UserStreak?
  deviceTokens      DeviceToken[]
  refreshTokens     MobileRefreshToken[]
  teamsCreated      Team[]         @relation("TeamCreator")
  teamMemberships   TeamMember[]
  attemptTags       AttemptTag[]   @relation("TaggedUser")
  
  // NextAuth
  accounts          Account[]
  sessions          Session[]
  
  @@index([email])
  @@index([username])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Challenge {
  id                      String            @id @default(cuid())
  creatorId               String
  title                   String            @db.VarChar(100)
  description             String            @db.VarChar(500)
  category                ChallengeCategory
  difficulty              Int               // 1-5
  basePoints              Int               @default(10)
  points                  Int               // calculated: basePoints * difficulty
  status                  ChallengeStatus   @default(ACTIVE)
  prerequisiteChallengeId String?
  aiReviewNote            String?           @db.Text
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt
  
  creator                 User              @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  prerequisiteChallenge   Challenge?        @relation("ChallengeChain", fields: [prerequisiteChallengeId], references: [id], onDelete: SetNull)
  unlocksChallenges       Challenge[]       @relation("ChallengeChain")
  attempts                Attempt[]
  
  @@index([creatorId])
  @@index([status])
  @@index([category])
  @@index([createdAt])
  @@index([prerequisiteChallengeId])
}

model Attempt {
  id              String                @id @default(cuid())
  userId          String
  challengeId     String
  status          AttemptStatus         @default(DRAFT)
  proofUrl        String?
  proofType       String?               // image/video MIME type
  proofMetadata   Json?                 // { originalName, size, mimeType, dimensions }
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  
  user            User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge       Challenge             @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  verificationVotes VerificationVote[]
  comments          AttemptComment[]
  upvotes           AttemptUpvote[]
  reactions         AttemptReaction[]
  tags              AttemptTag[]
  pointsLedger    PointsLedger?
  
  @@index([userId])
  @@index([challengeId])
  @@index([status])
  @@index([createdAt])
}

model VerificationVote {
  id          String                @id @default(cuid())
  attemptId   String
  voterId     String
  vote        VerificationVoteType
  reason      String?               @db.Text
  createdAt   DateTime              @default(now())
  
  attempt     Attempt               @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  voter       User                  @relation(fields: [voterId], references: [id], onDelete: Cascade)
  
  @@unique([attemptId, voterId])
  @@index([attemptId])
  @@index([voterId])
}

model AttemptComment {
  id        String   @id @default(cuid())
  attemptId String
  userId    String
  parentId  String?
  body      String   @db.VarChar(500)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  attempt Attempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent  AttemptComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies AttemptComment[] @relation("CommentReplies")
  upvotes AttemptCommentUpvote[]

  @@index([attemptId])
  @@index([userId])
  @@index([parentId])
  @@index([createdAt])
}

model AttemptCommentUpvote {
  id        String   @id @default(cuid())
  commentId String
  userId    String
  createdAt DateTime @default(now())

  comment AttemptComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@index([commentId])
}

model AttemptUpvote {
  id        String   @id @default(cuid())
  attemptId String
  userId    String
  createdAt DateTime @default(now())

  attempt Attempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([attemptId, userId])
  @@index([attemptId])
}

model AttemptReaction {
  id        String              @id @default(cuid())
  attemptId String
  userId    String
  type      AttemptReactionType
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  attempt Attempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([attemptId, userId])
  @@index([attemptId])
}

model Friendship {
  id          String            @id @default(cuid())
  requesterId String
  addresseeId String
  status      FriendshipStatus  @default(PENDING)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  
  requester   User              @relation("FriendRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee   User              @relation("FriendAddressee", fields: [addresseeId], references: [id], onDelete: Cascade)
  
  @@unique([requesterId, addresseeId])
  @@index([requesterId])
  @@index([addresseeId])
  @@index([status])
}

model MessageThread {
  id            String    @id @default(cuid())
  userAId       String
  userBId       String
  lastMessageAt DateTime  @default(now())
  createdAt     DateTime  @default(now())
  
  userA         User      @relation("ThreadUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB         User      @relation("ThreadUserB", fields: [userBId], references: [id], onDelete: Cascade)
  messages      Message[]
  
  @@unique([userAId, userBId])
  @@index([userAId])
  @@index([userBId])
  @@index([lastMessageAt])
}

model Message {
  id        String        @id @default(cuid())
  threadId  String
  senderId  String
  body      String        @db.Text
  readAt    DateTime?
  createdAt DateTime      @default(now())
  
  thread    MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender    User          @relation(fields: [senderId], references: [id], onDelete: Cascade)
  
  @@index([threadId])
  @@index([senderId])
  @@index([createdAt])
}

model Report {
  id          String            @id @default(cuid())
  reporterId  String
  targetType  ReportTargetType
  targetId    String
  reason      String
  details     String?           @db.Text
  status      ReportStatus      @default(OPEN)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  
  reporter    User              @relation(fields: [reporterId], references: [id], onDelete: Cascade)
  
  @@index([reporterId])
  @@index([targetType, targetId])
  @@index([status])
  @@index([createdAt])
}

model PointsLedger {
  id        String   @id @default(cuid())
  userId    String
  attemptId String   @unique
  points    Int
  createdAt DateTime @default(now())
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  attempt   Attempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([createdAt])
}

model Notification {
  id            String           @id @default(cuid())
  userId        String
  type          NotificationType
  referenceType String?
  referenceId   String?
  title         String
  body          String           @db.Text
  read          Boolean          @default(false)
  createdAt     DateTime         @default(now())
  
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([read])
  @@index([createdAt])
}

model UserStreak {
  userId           String    @id
  currentStreak    Int       @default(0)
  longestStreak    Int       @default(0)
  lastActivityDate DateTime?
  updatedAt        DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model AttemptTag {
  id           String   @id @default(cuid())
  attemptId    String
  taggedUserId String
  createdAt    DateTime @default(now())

  attempt    Attempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  taggedUser User    @relation("TaggedUser", fields: [taggedUserId], references: [id], onDelete: Cascade)

  @@unique([attemptId, taggedUserId])
  @@index([attemptId])
  @@index([taggedUserId])
}

model Team {
  id          String   @id @default(cuid())
  name        String   @db.VarChar(80)
  slug        String   @unique @db.VarChar(80)
  description String?  @db.VarChar(300)
  creatorId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  creator User         @relation("TeamCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  members TeamMember[]

  @@index([creatorId])
}

model TeamMember {
  id        String   @id @default(cuid())
  teamId    String
  userId    String
  role      TeamRole @default(MEMBER)
  joinedAt  DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([teamId])
  @@index([userId])
}

model DeviceToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  platform  String   // ios | android | web
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model MobileRefreshToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}
