# Environment — copy to .env and fill in values
# cp .env.example .env

# Database (matches docker-compose db service)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=wato
DB_PORT=5432
DATABASE_URL=postgresql://postgres:password@localhost:5432/wato

# Auth (required)
NEXTAUTH_SECRET=change-me-to-a-random-32-character-string
NEXTAUTH_URL=http://localhost:3000
# Required for NextAuth in Docker (Auth.js trusts the request host)
AUTH_TRUST_HOST=true

# App
APP_PORT=3000
STORAGE_PROVIDER=local

# Optional: Google OAuth
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Optional: S3 storage (use in production instead of local files)
# AWS_S3_BUCKET=
# AWS_S3_REGION=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Optional: distributed rate limiting
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
